#!/usr/bin/env bash
set -euo pipefail

HOOK_DIR="$(git rev-parse --show-toplevel)/.git/hooks"
mkdir -p "$HOOK_DIR"

cat > "$HOOK_DIR/pre-commit" << 'HOOK'
#!/usr/bin/env bash
set -euo pipefail

echo "[pre-commit] Running RuboCop..."

# Only check staged Ruby files
STAGED_FILES=$(git diff --cached --name-only --diff-filter=ACM | grep '\.rb$' || true)

if [ -z "$STAGED_FILES" ]; then
  echo "[pre-commit] No Ruby files staged. Skipping RuboCop."
  exit 0
fi

bundle exec rubocop --force-exclusion $STAGED_FILES

if [ $? -ne 0 ]; then
  echo ""
  echo "[pre-commit] RuboCop failed. Fix issues before committing."
  echo "  Run: bundle exec rubocop -a  (to auto-fix)"
  exit 1
fi
HOOK

chmod +x "$HOOK_DIR/pre-commit"
echo "✓ Pre-commit hook installed."
